#' Monte Carlo Numerical Integration
#'
#' @description
#' A function that returns a data frame with a column for x values
#' a column for y values, and a column determining whether the set
#' of points lies above the graph or on/ below the graph.
#' 
#' @param n integer The number of times the function is sampled 
#' (how many coordinate pairs to create)
#' @param upper_x numeric The upper Bounds of integration
#' @param lower_x numeric The lower Bounds of integration
#' @param upper_y numeric The upper Bounds of rectangular area 
#' @param lower_y numeric The lower Bounds of rectangular area 
#' 
#' @returns will return a data frame with x, y, and loaction columns  
#'
#' @details
#' The 'mon_carlo' function can take any user-specified resoution 
#' (i.e., number of points) while attending to user-specified bounds 
#' on x- and y-coordinates and return a data frame.


### Monte Carlo Simulation

mon_carlo <- function(n, upper_x, lower_x, upper_y, lower_y){
  # calculate area
  area <- (upper_x - lower_x) * (upper_y - lower_y)
  
  # SIMULATION
  simResults_x <- runif(
    n,
    min = lower_x,
    max = upper_x
  )
  
  simResults_y <- runif(
    n,
    min = lower_y,
    max = upper_y
  )
  
  coordinate_df<- data.frame(# Combine simulated results into a data frame
    x = simResults_x,
    y = simResults_y
  )
  
  return(coordinate_df)
}


## Wrangle the data

# Set up the function we will integrate 
f <- function(x){
  dbeta(x, shape1 = 2, shape2 = 2)
}

# Get the df from the mon_carlo function
lower_x = 0
upper_x = 1

lower_y = 0
upper_y = 1.5

n = 10000

df<- mon_carlo(n, upper_x, lower_x, upper_y, lower_y)

# Check where each ordered pair lies on the helper function
location<- sapply(
  X= df$x,# extract the x values from the df
  FUN = function(x){# apply our chosen function to each extracted element
    f(x)}
)

onFunction_vec <- numeric(n) # will include results of whether points above function or not
onBelow <- 0 # num of points on/ below function (helpful for proportion (p) later)

for (i in 1:n){
  y <- df$y[i] # extract single element from y column at index i
  if (y > location[i]){
    onFunction_vec[i]<- 'above' # above the func
  }else{
    onFunction_vec[i]<- 'on/bellow' # on/bellow the func
    onBelow <- onBelow +1
  }
}

# attach results to the data frame
setsOnFunction <- bind_cols(df, onFunction_vec)|>
  rename(position = 3) # name the new column


